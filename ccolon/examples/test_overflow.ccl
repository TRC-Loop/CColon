import console

function factorial(int n) int {
    var int result = 1
    for i in range(1, n + 1) {
        result = result * i
    }
    return result
}

function main() {
    for i in range(1, 25) {
        try {
            var int f = factorial(i)
            console.println(i.tostring() + "! = " + f.tostring())
        } catch (Error e) {
            console.println(i.tostring() + "! = overflow: " + e.message)
        }
    }
}
